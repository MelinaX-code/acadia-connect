# MariaDB / MySQL Connection
DB_HOST=localhost
DB_PORT=3306
# App DB user used by the server
DB_USER=acadia_connect_app
DB_PASSWORD=
DB_NAME=acadia_connect

# Admin credentials used for db:init-user and db:reset (create DB/user, grant privileges)
DB_ADMIN_USER=root
DB_ADMIN_PASSWORD=

# JWT Secret (change this to a strong secret in production)
JWT_SECRET=your-super-secret-key-change-this

# Server Port
PORT=3001

# Frontend base URL (used to build password reset links)
# Example for VS Code Live Server: http://127.0.0.1:5500/acadia-connect
FRONTEND_URL=http://127.0.0.1:5500/acadia-connect

# Password reset token TTL (minutes)
RESET_TOKEN_TTL_MINUTES=60

# SMTP settings (for Nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
